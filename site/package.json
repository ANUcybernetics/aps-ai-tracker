{
  "name": "aps-ai-transparency-tracker-site",
  "version": "0.0.0",
  "private": true,
  "description": "Timeline + similarity explorer for Australian Government AI transparency statements",
  "type": "module",
  "scripts": {
    "dev": "astro dev",
    "build": "astro build",
    "preview": "astro preview",
    "typecheck": "astro check && svelte-check --tsconfig ./tsconfig.json",
    "test": "vitest run",
    "lint": "oxlint",
    "lint:fix": "oxlint --fix",
    "lint:css": "stylelint \"src/**/*.css\"",
    "format": "oxfmt .",
    "format:check": "oxfmt --check ."
  },
  "dependencies": {
    "@astrojs/sitemap": "^3.7.3",
    "@astrojs/svelte": "^9.0.0",
    "@fontsource-variable/archivo": "^5.2.8",
    "@fontsource-variable/jetbrains-mono": "^5.2.8",
    "astro": "^7.0.4",
    "d3-drag": "^3.0.0",
    "d3-force": "^3.0.0",
    "d3-scale": "^4.0.2",
    "d3-selection": "^3.0.0",
    "d3-zoom": "^3.0.0",
    "diff-match-patch": "^1.0.5",
    "svelte": "^5.56.4"
  },
  "devDependencies": {
    "@astrojs/check": "^0.9.9",
    "@types/d3-drag": "^3.0.7",
    "@types/d3-force": "^3.0.10",
    "@types/d3-scale": "^4.0.9",
    "@types/d3-selection": "^3.0.11",
    "@types/d3-zoom": "^3.0.8",
    "@types/diff-match-patch": "^1.0.36",
    "@types/node": "^26.0.1",
    "oxfmt": "^0.57.0",
    "oxlint": "^1.72.0",
    "stylelint": "^17.14.0",
    "stylelint-config-standard": "^40.0.0",
    "svelte-check": "^4.7.1",
    "typescript": "^6.0.3",
    "vitest": "^4.1.9"
  },
  "engines": {
    "pnpm": ">=11"
  }
}
