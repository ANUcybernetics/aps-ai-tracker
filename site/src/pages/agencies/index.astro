---
import Layout from "@/components/Layout.astro";
import AgencyWall from "@/components/AgencyWall.astro";
import AgencyFinder from "@/islands/AgencyFinder.svelte";
import { getAgencies } from "@/lib/load";
import { SIZE_LABEL, originalityPercent } from "@/lib/format";
import { statementPath } from "@/lib/paths";

const agencies = await getAgencies();
const byName = (a: { name: string }, b: { name: string }) => a.name.localeCompare(b.name);
const published = agencies.filter((a) => a.status === "published").toSorted(byName);
const notYet = agencies.filter((a) => a.status === "not-yet").toSorted(byName);
const exempt = agencies.filter((a) => a.status === "exempt").toSorted(byName);
const finderAgencies = agencies.map((a) => ({ abbr: a.abbr, name: a.name, status: a.status }));
---

<Layout
  title="Agencies"
  description={`Which of the ${agencies.length} tracked Australian Government agencies have published an AI transparency statement, which haven't, and which are exempt.`}
>
  <div class="page stack">
    <header class="stack">
      <h1>Agencies</h1>
      <p class="lede">
        All {agencies.length} agencies on the APSC list. The Policy for the responsible
        use of AI in government <a
          href="https://www.digital.gov.au/ai/ai-in-government-policy#need-to-know"
          >applies to non-corporate Commonwealth entities</a
        >, which must publish an <a
          href="https://www.digital.gov.au/ai/ai-in-government-policy/standard-ai-transparency-statements"
          >AI transparency statement</a
        >; the intelligence and defence portfolios and corporate entities sit outside
        that mandate.
      </p>
    </header>

    <AgencyFinder client:load agencies={finderAgencies} label="Jump to an agency" />

    <AgencyWall />

    <section>
      <div class="section-title">
        <h2>Published</h2>
        <span class="muted">{published.length}</span>
      </div>
      <table class="agencies">
        <caption class="visually-hidden">Agencies with a published AI transparency statement</caption>
        <thead>
          <tr>
            <th scope="col">Agency</th>
            <th scope="col">Size</th>
            <th scope="col" class="num">Bespoke</th>
            <th scope="col" class="num">Revisions</th>
          </tr>
        </thead>
        <tbody>
          {
            published.map((a) => (
              <tr>
                <td>
                  <a href={statementPath(a.abbr)}>{a.name}</a>
                  <span class="muted mono"> {a.abbr}</span>
                </td>
                <td>{SIZE_LABEL[a.size]}</td>
                <td class="num">
                  {a.originality === null ? "—" : `${originalityPercent(a.originality)}%`}
                </td>
                <td class="num">{a.revisionCount}</td>
              </tr>
            ))
          }
        </tbody>
      </table>
    </section>

    {
      notYet.length > 0 && (
        <section>
          <div class="section-title">
            <h2>Not yet published</h2>
            <span class="muted">{notYet.length}</span>
          </div>
          <ul class="agency-list">
            {notYet.map((a) => (
              <li>
                {a.name} <span class="muted mono">{a.abbr}</span>
              </li>
            ))}
          </ul>
        </section>
      )
    }

    <section>
      <div class="section-title">
        <h2>Exempt or out of scope</h2>
        <span class="muted">{exempt.length}</span>
      </div>
      <p class="section-note">
        These agencies fall outside the Policy&rsquo;s mandatory scope &mdash; the
        intelligence and defence portfolios, and corporate Commonwealth entities. Some
        publish a statement voluntarily anyway; where they do, they appear under
        Published above and among the DTA&rsquo;s <a
          href="https://www.digital.gov.au/policy/ai/list-of-transparency-statements"
          >voluntary statements</a
        >.
      </p>
      <ul class="agency-list">
        {
          exempt.map((a) => (
            <li>
              {a.name} <span class="muted mono">{a.abbr}</span>
            </li>
          ))
        }
      </ul>
    </section>
  </div>
</Layout>

<style>
  .agencies {
    width: 100%;
    border-collapse: collapse;
    font-size: 0.92rem;
  }

  .agencies th {
    text-align: start;
    font-weight: 600;
    color: var(--muted);
    font-size: 0.8rem;
    text-transform: uppercase;
    letter-spacing: 0.04em;
    padding-block: var(--space-2);
    border-bottom: 1px solid var(--border);
  }

  .agencies td {
    padding-block: var(--space-2);
    border-bottom: 1px solid var(--border);
    vertical-align: baseline;
  }

  .agencies .num {
    text-align: end;
    font-variant-numeric: tabular-nums;
  }

  .section-note {
    color: var(--muted);
    max-width: 44rem;
    margin-block: calc(-1 * var(--space-2)) var(--space-4);
    font-size: 0.92rem;
  }

  .agency-list {
    list-style: none;
    margin: 0;
    padding: 0;
    columns: 18rem 2;
    gap: var(--space-5);
  }

  .agency-list li {
    padding-block: var(--space-1);
    break-inside: avoid;
  }
</style>
