---
import { passageToHtml } from "@/lib/markdown";
import { heatLevel } from "@/lib/format";
import PassageText from "@/components/PassageText.astro";
import type { PassageRow } from "@/types/exporter";

interface Member {
  abbr: string;
  name: string;
}

interface Props {
  passages: PassageRow[];
  // Other agencies sharing each passage, keyed by normKey (excludes this one).
  sharedBy?: Record<string, Member[]>;
}

const { passages, sharedBy = {} } = Astro.props;

type Item = { html: string; heat: number; tip: string; share: Member[]; template: boolean };
type Block =
  | { kind: "list"; items: Item[] }
  | ({ kind: "heading"; level: number } & Item)
  | ({ kind: "para" } & Item);

function tip(p: PassageRow): string {
  if (p.sharedCount >= 2) {
    const others = p.sharedCount - 1;
    return `Shared with ${others} other ${others === 1 ? "agency" : "agencies"}`;
  }
  return p.containsCanonicalPhrase ? "Template language" : "Unique to this statement";
}

// A passage is "template wording" when it carries canonical phrasing but isn't
// otherwise tied to named agencies or a shared count — the tip() fallthrough
// case. Those get the cool template wash (heat 0, off the amber ramp) so the
// popover-less match reads as its own kind rather than faint cross-agency reuse.
// Passage text renders through the same escape-first pipeline as the passage
// browser (lib/markdown.ts), so scraped text is safe for set:html.
function classify(p: PassageRow): Item {
  const share = sharedBy[p.normKey] ?? [];
  const template = !share.length && p.sharedCount < 2 && p.containsCanonicalPhrase;
  const heat = template ? 0 : heatLevel(p.sharedCount, p.containsCanonicalPhrase);
  return { html: passageToHtml(p.rawText), heat, tip: tip(p), share, template };
}

// Wrapper attributes shared by every passage element (heat wash + tooltip; the
// title is dropped when a ReuseChip carries the same information).
const heatAttrs = (x: Item) => ({
  class: "heat",
  "data-heat": x.heat,
  "data-variant": x.template ? "template" : undefined,
  title: x.share.length ? undefined : x.tip,
});

// Demote statement headings to sit under the page <h1>, normalising so the
// shallowest heading becomes <h2> — avoids an h1 → h3 jump when a scraped
// statement starts at "##".
const headingDepths = passages
  .filter((p) => p.kind === "heading")
  .map((p) => /^(#{1,6})/.exec(p.rawText)?.[1].length ?? 1);
const headingOffset = headingDepths.length ? 2 - Math.min(...headingDepths) : 1;

const blocks: Block[] = [];
let i = 0;
while (i < passages.length) {
  const p = passages[i];
  if (p.kind === "list_item") {
    const items: Item[] = [];
    while (i < passages.length && passages[i].kind === "list_item") {
      items.push(classify(passages[i]));
      i++;
    }
    blocks.push({ kind: "list", items });
  } else if (p.kind === "heading") {
    const hashes = /^(#{1,6})/.exec(p.rawText);
    const raw = hashes ? hashes[1].length : 1;
    const level = Math.min(Math.max(raw + headingOffset, 2), 6);
    blocks.push({ kind: "heading", level, ...classify(p) });
    i++;
  } else {
    blocks.push({ kind: "para", ...classify(p) });
    i++;
  }
}
---

<div class="statement-body prose">
  {
    blocks.map((b) => {
      if (b.kind === "list") {
        return (
          <ul>
            {b.items.map((it) => (
              <li {...heatAttrs(it)}>
                <PassageText {...it} />
              </li>
            ))}
          </ul>
        );
      }
      if (b.kind === "heading") {
        const Tag = `h${b.level}` as "h2";
        return (
          <Tag {...heatAttrs(b)}>
            <PassageText {...b} />
          </Tag>
        );
      }
      return (
        <p {...heatAttrs(b)}>
          <PassageText {...b} />
        </p>
      );
    })
  }
</div>
