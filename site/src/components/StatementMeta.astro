---
import type { StatementDoc } from "@/types/exporter";

interface Props {
  doc: StatementDoc;
}

const { doc } = Astro.props;
const redirectHost =
  doc.finalUrl && doc.finalUrl !== doc.sourceUrl ? new URL(doc.finalUrl).hostname : null;
---

<div class="stmt-meta">
  {doc.sourceType === "pdf" && <span class="pill pill--pdf">PDF source</span>}
  {
    doc.sourceUrl && (
      <a href={doc.sourceUrl} rel="nofollow noopener" target="_blank">
        View the original &nearr;
      </a>
    )
  }
  {redirectHost && <span class="muted">redirects to {redirectHost}</span>}
</div>

<style>
  .stmt-meta {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: var(--space-2) var(--space-4);
    font-size: 0.9rem;
  }
</style>
