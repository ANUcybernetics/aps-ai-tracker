---
import { wordDiffHtml, compactWordDiffHtml } from "@/lib/diff";

interface Props {
  before: string;
  after: string;
  compact?: boolean;
}

const { before, after, compact = false } = Astro.props;
const html = compact
  ? compactWordDiffHtml(before, after)
  : wordDiffHtml(before, after);
---

<div class="diff" set:html={html}></div>

<style>
  .diff {
    margin-block-start: var(--space-2);
    padding: var(--space-3);
    background: var(--surface);
    border-radius: var(--radius-sm);
    font-size: 0.9rem;
    line-height: 1.7;
    white-space: pre-wrap;
    overflow-wrap: anywhere;
  }
</style>
